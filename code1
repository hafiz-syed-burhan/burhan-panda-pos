#include <gtk/gtk.h>
#include <stdio.h>
#include <string.h>

// ==================== PREMIUM CSS STYLING ====================
const char *MODERN_CSS = 
    "* { font-family: 'Segoe UI', sans-serif; }"
    "window { background: linear-gradient(135deg, #1e272e, #2f3640); }"
    ".sidebar { background: rgba(0, 0, 0, 0.3); border-right: 1px solid rgba(255,255,255,0.1); padding: 20px; }"
    ".nav-btn { background: none; color: #dcdde1; border-radius: 8px; margin-bottom: 10px; padding: 12px; font-weight: 500; border: none; transition: all 0.3s; }"
    ".nav-btn:hover { background: rgba(255,255,255,0.1); color: #4cd137; }"
    ".active-nav { background: #4cd137; color: white; }"
    
    ".product-card { background: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 15px; padding: 20px; transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); }"
    ".product-card:hover { background: #4cd137; border-color: #4cd137; transform: translateY(-5px); box-shadow: 0 10px 20px rgba(76, 209, 55, 0.3); }"
    ".product-name { color: white; font-size: 18px; font-weight: bold; }"
    ".product-price { color: #4cd137; font-size: 14px; }"
    ".product-card:hover .product-price { color: white; }"
    
    ".cart-panel { background: white; border-radius: 25px 0 0 25px; padding: 25px; box-shadow: -10px 0 30px rgba(0,0,0,0.2); }"
    ".total-box { background: #f5f6fa; border-radius: 15px; padding: 20px; margin-top: 20px; }"
    ".total-val { font-size: 32px; font-weight: 800; color: #2f3640; }"
    ".pay-btn { background: #4cd137; color: white; border-radius: 12px; font-size: 20px; font-weight: bold; border: none; padding: 15px; box-shadow: 0 5px 15px rgba(76, 209, 55, 0.4); }";

typedef struct { char *name; int price; } Product;
Product catalog[] = {
    {"Espresso", 250}, {"Latte Art", 450}, {"Croissant", 350}, 
    {"Steak Sandwich", 850}, {"Fruit Bowl", 400}, {"Iced Tea", 150},
    {"Club Sandwich", 600}, {"Pasta", 750}, {"Cheesecake", 500}
};

GtkWidget *main_win, *login_win, *total_lbl;
GtkListStore *cart_store;
int total_bill = 0;

void apply_style() {
    GtkCssProvider *provider = gtk_css_provider_new();
    gtk_css_provider_load_from_data(provider, MODERN_CSS, -1, NULL);
    gtk_style_context_add_provider_for_screen(gdk_screen_get_default(), 
        GTK_STYLE_PROVIDER(provider), GTK_STYLE_PROVIDER_PRIORITY_USER);
}

void add_to_bill(GtkWidget *w, gpointer data) {
    int i = GPOINTER_TO_INT(data);
    GtkTreeIter iter;
    gtk_list_store_append(cart_store, &iter);
    gtk_list_store_set(cart_store, &iter, 0, catalog[i].name, 1, catalog[i].price, -1);
    
    total_bill += catalog[i].price;
    char buf[64]; sprintf(buf, "Rs. %d", total_bill);
    gtk_label_set_text(GTK_LABEL(total_lbl), buf);
}

void open_dashboard() {
    main_win = gtk_window_new(GTK_WINDOW_TOPLEVEL);
    gtk_window_set_title(GTK_WINDOW(main_win), "VIP TERMINAL v3.0");
    gtk_window_set_default_size(GTK_WINDOW(main_win), 1200, 750);
    g_signal_connect(main_win, "destroy", G_CALLBACK(gtk_main_quit), NULL);

    GtkWidget *layout = gtk_box_new(GTK_ORIENTATION_HORIZONTAL, 0);
    gtk_container_add(GTK_CONTAINER(main_win), layout);

    // --- SIDEBAR ---
    GtkWidget *side = gtk_box_new(GTK_ORIENTATION_VERTICAL, 0);
    gtk_style_context_add_class(gtk_widget_get_style_context(side), "sidebar");
    gtk_widget_set_size_request(side, 240, -1);
    gtk_box_pack_start(GTK_BOX(layout), side, FALSE, FALSE, 0);

    GtkWidget *brand = gtk_label_new("VIP SYSTEM");
    gtk_box_pack_start(GTK_BOX(side), brand, FALSE, FALSE, 40);

    const char *tabs[] = {" Dashboard", " Orders", "📦 Inventory", " Reports", "⚙ Settings"};
    for(int i=0; i<5; i++) {
        GtkWidget *btn = gtk_button_new_with_label(tabs[i]);
        gtk_style_context_add_class(gtk_widget_get_style_context(btn), "nav-btn");
        if(i==0) gtk_style_context_add_class(gtk_widget_get_style_context(btn), "active-nav");
        gtk_box_pack_start(GTK_BOX(side), btn, FALSE, FALSE, 0);
    }

    // --- PRODUCT GRID ---
    GtkWidget *scroll = gtk_scrolled_window_new(NULL, NULL);
    gtk_box_pack_start(GTK_BOX(layout), scroll, TRUE, TRUE, 30);
    
    GtkWidget *grid = gtk_grid_new();
    gtk_grid_set_row_spacing(GTK_GRID(grid), 20);
    gtk_grid_set_column_spacing(GTK_GRID(grid), 20);
    gtk_container_add(GTK_CONTAINER(scroll), grid);

    for (int i = 0; i < 9; i++) {
        GtkWidget *card = gtk_button_new();
        gtk_style_context_add_class(gtk_widget_get_style_context(card), "product-card");
        
        GtkWidget *v = gtk_box_new(GTK_ORIENTATION_VERTICAL, 5);
        GtkWidget *n = gtk_label_new(catalog[i].name);
        gtk_style_context_add_class(gtk_widget_get_style_context(n), "product-name");
        char pbuf[32]; sprintf(pbuf, "Rs. %d", catalog[i].price);
        GtkWidget *p = gtk_label_new(pbuf);
        gtk_style_context_add_class(gtk_widget_get_style_context(p), "product-price");
        
        gtk_box_pack_start(GTK_BOX(v), n, FALSE, FALSE, 0);
        gtk_box_pack_start(GTK_BOX(v), p, FALSE, FALSE, 0);
        gtk_container_add(GTK_CONTAINER(card), v);
        
        g_signal_connect(card, "clicked", G_CALLBACK(add_to_bill), GINT_TO_POINTER(i));
        gtk_grid_attach(GTK_GRID(grid), card, i % 3, i / 3, 1, 1);
    }

    // --- CART PANEL ---
    GtkWidget *cart = gtk_box_new(GTK_ORIENTATION_VERTICAL, 0);
    gtk_style_context_add_class(gtk_widget_get_style_context(cart), "cart-panel");
    gtk_widget_set_size_request(cart, 380, -1);
    gtk_box_pack_start(GTK_BOX(layout), cart, FALSE, FALSE, 0);

    GtkWidget *cl = gtk_label_new("Current Order");
    gtk_box_pack_start(GTK_BOX(cart), cl, FALSE, FALSE, 20);

    cart_store = gtk_list_store_new(2, G_TYPE_STRING, G_TYPE_INT);
    GtkWidget *view = gtk_tree_view_new_with_model(GTK_TREE_MODEL(cart_store));
    GtkCellRenderer *r = gtk_cell_renderer_text_new();
    gtk_tree_view_insert_column_with_attributes(GTK_TREE_VIEW(view), -1, "Item", r, "text", 0, NULL);
    gtk_tree_view_insert_column_with_attributes(GTK_TREE_VIEW(view), -1, "Price", r, "text", 1, NULL);
    
    GtkWidget *cscroll = gtk_scrolled_window_new(NULL, NULL);
    gtk_container_add(GTK_CONTAINER(cscroll), view);
    gtk_box_pack_start(GTK_BOX(cart), cscroll, TRUE, TRUE, 0);

    GtkWidget *tbox = gtk_box_new(GTK_ORIENTATION_VERTICAL, 5);
    gtk_style_context_add_class(gtk_widget_get_style_context(tbox), "total-box");
    total_lbl = gtk_label_new("Rs. 0");
    gtk_style_context_add_class(gtk_widget_get_style_context(total_lbl), "total-val");
    gtk_box_pack_start(GTK_BOX(tbox), gtk_label_new("GRAND TOTAL"), FALSE, FALSE, 0);
    gtk_box_pack_start(GTK_BOX(tbox), total_lbl, FALSE, FALSE, 0);
    gtk_box_pack_start(GTK_BOX(cart), tbox, FALSE, FALSE, 20);

    GtkWidget *pay = gtk_button_new_with_label("PROCESS PAYMENT");
    gtk_style_context_add_class(gtk_widget_get_style_context(pay), "pay-btn");
    gtk_box_pack_start(GTK_BOX(cart), pay, FALSE, FALSE, 0);

    gtk_widget_show_all(main_win);
}

void on_login_action(GtkWidget *b, gpointer d) {
    GtkWidget **e = (GtkWidget **)d;
    if (strcmp(gtk_entry_get_text(GTK_ENTRY(e[0])), "admin") == 0 && 
        strcmp(gtk_entry_get_text(GTK_ENTRY(e[1])), "1234") == 0) {
        gtk_widget_destroy(login_win);
        open_dashboard();
    }
}

int main(int argc, char *argv[]) {
    gtk_init(&argc, &argv);
    apply_style();

    login_win = gtk_window_new(GTK_WINDOW_TOPLEVEL);
    gtk_window_set_default_size(GTK_WINDOW(login_win), 400, 500);
    gtk_window_set_position(GTK_WINDOW(login_win), GTK_WIN_POS_CENTER);

    GtkWidget *vb = gtk_box_new(GTK_ORIENTATION_VERTICAL, 25);
    gtk_container_set_border_width(GTK_CONTAINER(vb), 50);
    gtk_container_add(GTK_CONTAINER(login_win), vb);

    GtkWidget *title = gtk_label_new("TERMINAL LOGIN");
    gtk_box_pack_start(GTK_BOX(vb), title, FALSE, FALSE, 20);

    static GtkWidget *ents[2];
    ents[0] = gtk_entry_new();
    gtk_entry_set_placeholder_text(GTK_ENTRY(ents[0]), "Username");
    ents[1] = gtk_entry_new();
    gtk_entry_set_placeholder_text(GTK_ENTRY(ents[1]), "Password");
    gtk_entry_set_visibility(GTK_ENTRY(ents[1]), FALSE);

    GtkWidget *lb = gtk_button_new_with_label("AUTHENTICATE");
    gtk_style_context_add_class(gtk_widget_get_style_context(lb), "pay-btn");
    g_signal_connect(lb, "clicked", G_CALLBACK(on_login_action), ents);

    gtk_box_pack_start(GTK_BOX(vb), ents[0], FALSE, FALSE, 0);
    gtk_box_pack_start(GTK_BOX(vb), ents[1], FALSE, FALSE, 0);
    gtk_box_pack_start(GTK_BOX(vb), lb, FALSE, FALSE, 10);

    gtk_widget_show_all(login_win);
    gtk_main();
    return 0;
}
